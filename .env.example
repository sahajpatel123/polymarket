# Copy to .env and fill in. Never commit .env.

# Signer private key (hex, with or without 0x)
PK=

# Polymarket funder / deposit address (holds pUSD and positions).
# For signature_type 1/2/3 this is the proxy/deposit wallet, NOT the signing EOA.
BROWSER_ADDRESS=

# Optional overrides
# POLYGON_RPC=https://polygon-bor-rpc.publicnode.com
# ALL_PROXY=socks5://127.0.0.1:1080
# ALERT_WEBHOOK_URL=

# Required only to merge YES+NO via a V2 DepositWallet (signature_type 1 or 3).
# Generate with the CLOB client's create_builder_api_key.
# POLY_BUILDER_KEY=
# POLY_BUILDER_SECRET=
# POLY_BUILDER_PASSPHRASE=
# POLY_RELAYER_URL=https://relayer-v2.polymarket.com
